# Neon Postgres connection string
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/renexis?sslmode=require"

# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET="change_this_to_a_long_random_string"
JWT_EXPIRES_IN="8h"
REFRESH_TOKEN_SECRET="change_this_to_another_long_random_string"
REFRESH_TOKEN_EXPIRES_IN="7d"

# CORS - comma separated list of allowed origins (your Vercel frontend URL)
CORS_ORIGINS="http://localhost:3000,http://localhost:8081"

# Optional: FX rate API
FX_API_KEY=""
FX_API_BASE_URL="https://api.exchangerate.host"

# Optional: Market data API for investments
MARKET_DATA_API_KEY=""
